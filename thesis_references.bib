@article{kruskal_three-way_1977,
	title = {Three-way arrays: rank and uniqueness of trilinear decompositions, with application to arithmetic complexity and statistics},
	volume = {18},
	issn = {0024-3795},
	shorttitle = {Three-way arrays},
	url = {https://www.sciencedirect.com/science/article/pii/0024379577900696},
	doi = {10.1016/0024-3795(77)90069-6},
	abstract = {A three-way array X (or three-dimensional matrix) is an array of numbers xijk subscripted by three indices. A triad is a multiplicative array, xijk = aibjck. Analogous to the rank and the row rank of a matrix, we define rank (X) to be the minimum number of triads whose sum is X, and dim1(X) to be the dimensionality of the space of matrices generated by the 1-slabs of X. (Rank and dim1 may not be equal.) We prove several lower bounds on rank. For example, a special case of Theorem 1 is that rank(X)⩾dim1(UX) + rank(XW) − dim1(UXW), where U and W are matrices; this generalizes a matrix theorem of Frobenius. We define the triple product [A, B, C] of three matrices to be the three-way array whose (i, j, k) element is given by ⩞rairbjrckr; in other words, the triple product is the sum of triads formed from the columns of A, B, and C. We prove several sufficient conditions for the factors of a triple product to be essentially unique. For example (see Theorem 4a), suppose [A, B, C] = [Ā, B̄, C̄], and each of the matrices has R columns. Suppose every set of rank (A) columns of A are independent, and similar conditions hold for B and C. Suppose rank (A) + rank (B) + rank (C) ⩾ 2R + 2. Then there exist diagonal matrices Λ, M, N and a permutation matrix P such that Ā = APΛ, B̄ = BPM, C̄ = CPN. Our results have applications to arithmetic complexity theory and to statistical models used in three-way multidimensional scaling.},
	number = {2},
	urldate = {2025-04-15},
	journal = {Linear Algebra and its Applications},
	author = {Kruskal, Joseph B.},
	month = jan,
	year = {1977},
	keywords = {Unread},
	pages = {95--138},
	file = {1-s2.0-0024379577900696-main:D\:\\MastersMaterial\\Courses Passed\\ARC Readings\\1-s2.0-0024379577900696-main.pdf:application/pdf;ScienceDirect Snapshot:C\:\\Users\\Lael John\\Zotero\\storage\\7AWY5DS3\\0024379577900696.html:text/html},
}

@article{brambilla_alexanderhirschowitz_2008,
	title = {On the {Alexander}–{Hirschowitz} theorem},
	volume = {212},
	copyright = {https://www.elsevier.com/tdm/userlicense/1.0/},
	issn = {00224049},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0022404907002344},
	doi = {10.1016/j.jpaa.2007.09.014},
	abstract = {The Alexander–Hirschowitz theorem says that a general collection of k double points in Pn imposes independent conditions on homogeneous polynomials of degree d with a well-known list of exceptions. Alexander and Hirschowitz completed its proof in 1995, solving a long standing classical problem, connected with the Waring problem for polynomials. We expose a self-contained proof based mainly on the previous works by Terracini, Hirschowitz, Alexander and Chandler, with a few simpliﬁcations. We claim originality only in the case d = 3, where our proof is shorter. We end with an account of the history of the work on this problem.},
	language = {en},
	number = {5},
	urldate = {2025-04-15},
	journal = {Journal of Pure and Applied Algebra},
	author = {Brambilla, Maria Chiara and Ottaviani, Giorgio},
