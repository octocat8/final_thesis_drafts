@article{buczynska_secant_2013,
	title = {Secant varieties to high degree {Veronese} reembeddings, catalecticant matrices and smoothable {Gorenstein} schemes},
	volume = {23},
	copyright = {https://www.ams.org/publications/copyright-and-permissions},
